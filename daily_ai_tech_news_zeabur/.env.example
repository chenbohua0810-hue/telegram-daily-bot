# Copy these keys into Zeabur Variables manually.
# Do not commit real secrets.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TZ=Asia/Taipei
SEND_HOUR=8
SEND_MINUTE=0
ITEM_LIMIT=5

# Optional: comma-separated or newline-separated RSS URLs.
# Leave empty to use the built-in public tech/AI sources.
NEWS_RSS_URLS=

# Optional one-shot test mode. Keep false/empty in production.
RUN_ONCE=
GEMINI_API_KEY=
TRANSLATE_TITLES=true
TRANSLATION_MODEL=gemini-2.5-flash
