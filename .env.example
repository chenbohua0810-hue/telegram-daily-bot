# Core trading
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
PAPER_TRADING=true

# Claude / Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_SCORER_MODEL=claude-haiku-4-5-20251001

# LLM routing
LLM_PRIMARY_NAME=groq
LLM_PRIMARY_BASE_URL=https://api.groq.com/openai/v1
LLM_PRIMARY_MODEL=llama-3.3-70b-versatile
LLM_PRIMARY_API_KEY=your-primary-llm-api-key

LLM_SECONDARY_NAME=
LLM_SECONDARY_BASE_URL=
LLM_SECONDARY_MODEL=
LLM_SECONDARY_API_KEY=

# Chain data
ETHERSCAN_API_KEY=your-etherscan-api-key
SOLSCAN_API_KEY=your-solscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key

# Sentiment + notifications
CRYPTOPANIC_API_KEY=your-cryptopanic-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Risk / execution
MIN_TRADE_USD=10000
MAX_POSITION_PCT=0.10
DAILY_LOSS_CIRCUIT=-0.05
MAX_CONCURRENT_POSITIONS=10
POLL_INTERVAL_SECONDS=60
AI_SCORER_CONFIDENCE_THRESHOLD=60
HIGH_VALUE_USD_THRESHOLD=50000
P1_HIGH_TRUST_MIN_USD=20000
P1_HIGH_TRUST_RECENT_WINRATE=0.60

# Batch scorer
BATCH_WINDOW_SECONDS=5
BATCH_MAX_SIZE=5
BATCH_MAX_INPUT_TOKENS=6000

# WebSocket monitors
USE_WEBSOCKET=true
ETH_WSS_URL=
SOL_WSS_URL=
BSC_WSS_URL=
WS_HEARTBEAT_TIMEOUT_SECONDS=60
WS_RECONNECT_BACKOFF_CAP_SECONDS=60

# Local storage
ADDRESSES_DB_PATH=data/addresses.db
TRADES_DB_PATH=data/trades.db
EVENTS_LOG_PATH=data/events.jsonl
